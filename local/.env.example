# =====================================================================
# CP Catalog — local environment configuration
# Copy to local/.env and fill in the values for your laptop.
# =====================================================================

# ---- Oracle catalog DB (the schema you just created) ----------------
# Format: oracle://<user>:<password>@<host>:<port>/<service_name>
# Local Oracle Free container example:
CP_CATALOG_DB_DSN=oracle://catalog_user:catalogpwd@localhost:1521/FREEPDB1

# ---- Shared folder root (where your artifacts live) -----------------
# Point this at the shared folder accessible from your laptop.
# Windows mapped drive example:   Z:\CP-CATALOG
# Windows UNC example:            \\qcwebfs.testbbh.com\fixed_income_quant_jupyter$\CP-CATALOG
# macOS mounted share example:    /Volumes/CP-CATALOG
# Or the bundled samples:         ./sample-artifacts
CP_CATALOG_ROOT=./sample-artifacts

# ---- Per-artifact paths (derived from CP_CATALOG_ROOT) --------------
# These are what the connectors actually read. The launcher sets them
# from CP_CATALOG_ROOT automatically, but you can override any of them.
INTERFACE360_XLSX_PATH=${CP_CATALOG_ROOT}/INTERFACE-SYSTEM/interfaces.xlsx
DATA360_FEED_DICTIONARY_PATH=${CP_CATALOG_ROOT}/DATA-FEEDS/SWP_EOD_Data_Feeds.xlsx
PII_ATTRIBUTES_PATH=${CP_CATALOG_ROOT}/OVERLAY/PII_Attributes_List.xlsx

# ---- Project resolution --------------------------------------------
SEI_ORACLE_SCHEMAS=SEI_RAW,SEI_STAGE

# ---- dbt harvest (optional; comment out to skip) --------------------
DBT_MANIFEST_PATH=${CP_CATALOG_ROOT}/dbt-artifacts/manifest.json
# DBT_CATALOG_PATH=${CP_CATALOG_ROOT}/dbt-artifacts/catalog.json
DBT_DIALECT=oracle

# ---- Oracle source harvest (optional; comment out to skip) ----------
# The production Oracle you harvest table/column metadata FROM (read-only).
# ORACLE_PROD_DSN=oracle://reader:pwd@oraprod:1521/PROD
# ORACLE_PROD_SCHEMAS=PBDW,IMDW,RISK,SEI_RAW,SEI_STAGE
# ORACLE_PLATFORM_ID=ora

# ---- Airflow harvest -------------------------------------------------
# LOCAL: read simulated metadata from the bundled JSON (no Postgres needed):
AIRFLOW_DSN=file://./sample-artifacts/airflow-sim/airflow_metadata.json
# OPENSHIFT (later): swap to the real Airflow Postgres metadata DB:
# AIRFLOW_DSN=postgresql://airflow:pwd@airflow-postgres:5432/airflow
AIRFLOW_DAGS_FILTER=

# ---- API runtime ----------------------------------------------------
ENVIRONMENT=dev
CATALOG_DISABLE_SECURITY=true
CORS_ORIGINS=http://localhost:5173
